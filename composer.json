{
  "name": "inventas/momentum-lock",
  "description": "Expose Laravel authorization abilities on the frontend for Laravel Data resources.",
  "keywords": [
    "authorization",
    "inertia",
    "inventas",
    "laravel",
    "permissions"
  ],
  "homepage": "https://github.com/Inventas/momentum-lock",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Boris Lepikhin",
      "email": "boris@lepikhin.com",
      "role": "Original author"
    },
    {
      "name": "Lennart Fischer",
      "email": "info@lambdadigamma.com",
      "role": "Maintainer"
    }
  ],
  "autoload": {
    "psr-4": {
      "Momentum\\Lock\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Momentum\\Lock\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.3",
    "illuminate/support": "^12.0|^13.0",
    "illuminate/auth": "^12.0|^13.0",
    "spatie/laravel-data": "^4.0",
    "spatie/laravel-typescript-transformer": "^2.6"
  },
  "require-dev": {
    "orchestra/testbench": "^10.0|^11.0",
    "larastan/larastan": "^3.0",
    "laravel/pint": "^1.29",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0"
  },
  "scripts": {
    "analyse": "vendor/bin/phpstan analyse",
    "format": "vendor/bin/pint",
    "test": "vendor/bin/pest"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Momentum\\Lock\\LockServiceProvider"
      ]
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "support": {
    "issues": "https://github.com/Inventas/momentum-lock/issues",
    "source": "https://github.com/Inventas/momentum-lock"
  }
}
